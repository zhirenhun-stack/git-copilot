#!/usr/bin/env python3
"""git-copilot — Smart conventional commit message generator (standalone).

Usage:
  curl -sL https://raw.githubusercontent.com/zhirenhun-stack/git-copilot/main/git-copilot | python3 - gen
"""
import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

CONFIG_DIR = Path.home() / ".config" / "git-copilot"
CONFIG_FILE = CONFIG_DIR / "config.json"

DEFAULT_CONFIG = {
    "types": {
        "feat": {"description": "A new feature", "emoji": "✨"},
        "fix": {"description": "A bug fix", "emoji": "🐛"},
        "docs": {"description": "Documentation only", "emoji": "📝"},
        "style": {"description": "Code style", "emoji": "💄"},
        "refactor": {"description": "Code change neither fixes a bug nor adds a feature", "emoji": "♻️"},
        "perf": {"description": "Performance improvement", "emoji": "⚡"},
        "test": {"description": "Adding tests", "emoji": "✅"},
        "build": {"description": "Build system", "emoji": "📦"},
        "ci": {"description": "CI/CD config", "emoji": "👷"},
        "chore": {"description": "Other changes", "emoji": "🔧"},
        "revert": {"description": "Reverts a commit", "emoji": "⏪"},
    },
    "max_subject_length": 72,
    "include_scope": True,
    "breaking_change_marker": "!",
}

FILE_TYPE_MAP = {
    ".py": "feat", ".js": "feat", ".ts": "feat", ".jsx": "feat", ".tsx": "feat",
    ".css": "style", ".scss": "style", ".less": "style",
    ".md": "docs", ".rst": "docs", ".txt": "docs",
    ".json": "chore", ".yaml": "chore", ".yml": "chore", ".toml": "chore",
    ".ini": "chore", ".cfg": "chore",
    "_test.py": "test", "_spec.py": "test", ".test.js": "test", ".spec.js": "test",
    ".test.ts": "test", ".spec.ts": "test",
    "Dockerfile": "build", ".dockerignore": "build",
    "Makefile": "build", "CMakeLists.txt": "build",
}

SCOPE_MAP = {
    "api": ["api", "route", "endpoint", "controller", "handler"],
    "ui": ["ui", "component", "page", "view", "template", "css", "style"],
    "db": ["db", "database", "migration", "sql", "query", "model"],
    "auth": ["auth", "login", "session", "permission", "role"],
    "config": ["config", "env", "setting", "conf"],
    "docs": ["doc", "readme", "changelog", "contributing"],
    "ci": ["ci", "github", "actions", "workflow", "docker"],
    "cli": ["cli", "command", "argument", "flag"],
}


def run_git(*args):
    try:
        r = subprocess.run(["git", *args], capture_output=True, text=True, check=True, timeout=10)
        return r.stdout.strip()
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
        return ""


def get_staged_files():
    return [f for f in run_git("diff", "--cached", "--name-only").split("\n") if f.strip()]


def get_diff_stat():
    return run_git("diff", "--cached", "--stat")


def detect_breaking_changes(files):
    for f in files:
        if "migration" in f.lower() or "breaking" in f.lower():
            return True
        diff = run_git("diff", "--cached", "-U0", "--", f)
        if "BREAKING CHANGE" in diff:
            return True
    return False


def infer_type(files):
    has_src, has_test, has_docs, has_config, has_style, has_build = False, False, False, False, False, False
    for f in files:
        lower, ext, name = f.lower(), Path(f).suffix.lower(), Path(f).name
        if any(t in lower for t in ["test", "spec"]): has_test = True; continue
        if ext in (".md", ".rst", ".txt"): has_docs = True; continue
        if ext in (".json", ".yaml", ".yml", ".toml", ".ini", ".cfg"): has_config = True; continue
        if ext in (".css", ".scss", ".less"): has_style = True; continue
        if name in ("Dockerfile", "Makefile", "CMakeLists.txt") or "/ci/" in lower: has_build = True; continue
        has_src = True
    if has_test and not has_src: return "test"
    if has_docs and not has_src: return "docs"
    if has_config and not has_src: return "chore"
    if has_style: return "style"
    if has_build: return "build"
    return "feat" if has_src else "chore"


def infer_scope(files):
    text = " ".join(f.lower() for f in files)
    best, scope = 0, ""
    for s, kws in SCOPE_MAP.items():
        score = sum(1 for kw in kws if kw in text)
        if score > best: best, scope = score, s
    return scope


def summarize_changes(files, diff_stat):
    cf, ins, d = len(files), 0, 0
    for line in diff_stat.split("\n"):
        for p in line.split():
            if p.startswith("+"):
                try: ins += int(p.replace("+","").replace(",",""))
                except: pass
            elif p.startswith("-"):
                try: d += int(p.replace("-","").replace(",",""))
                except: pass
    return f"{cf} file(s), +{ins}/-{d} lines"


def gen_subject(commit_type, files):
    names = [Path(f).name for f in files[:5]]
    verbs = {"feat": "add", "fix": "fix", "docs": "update", "refactor": "refactor", "test": "add tests for", "chore": "update"}
    verb = verbs.get(commit_type, "update")
    if commit_type == "test" and names:
        test_f = [f for f in names if "test" in f.lower() or "spec" in f.lower()]
        if test_f: return f"add tests for {', '.join(test_f[:3])}"
        return "update tests"
    return f"{verb} {', '.join(names[:3])}"


def load_config():
    if CONFIG_FILE.exists():
        try: return json.loads(CONFIG_FILE.read_text())
        except: pass
    return dict(DEFAULT_CONFIG)


def cmd_gen(force_type=""):
    files = get_staged_files()
    if not files:
        print("⚠️  No staged changes. Run: git add <files>")
        sys.exit(1)
    diff_stat = get_diff_stat()
    config = load_config()
    ct = force_type or infer_type(files)
    if ct not in config["types"]: ct = "chore"
    scope = f"({infer_scope(files)})" if config.get("include_scope") and infer_scope(files) else ""
    breaking = detect_breaking_changes(files)
    bm = config["breaking_change_marker"] if breaking else ""
    subject = gen_subject(ct, files)
    max_len = config.get("max_subject_length", 72)
    if len(subject) > max_len: subject = subject[:max_len-3] + "..."
    emoji = config["types"].get(ct, {}).get("emoji", "")
    header = f"{emoji} {ct}{scope}{bm}: {subject}".strip()
    body = f"\n\n{summarize_changes(files, diff_stat)}"
    if breaking: body += "\n\nBREAKING CHANGE: This commit introduces a breaking API change."
    print(f"{header}{body}")


def main():
    p = argparse.ArgumentParser(description="git-copilot — Smart commit message generator")
    p.add_argument("--version", action="version", version="1.0.0")
    sp = p.add_subparsers(dest="command")
    gen = sp.add_parser("gen", help="Generate commit message from staged changes")
    gen.add_argument("--type", "-t", help="Force commit type")
    sp.add_parser("init", help="Create default config")
    sp.add_parser("config", help="Show current config")
    args = p.parse_args()
    if args.command == "init":
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        CONFIG_FILE.write_text(json.dumps(DEFAULT_CONFIG, indent=2))
        print(f"✅ Config created at {CONFIG_FILE}")
    elif args.command == "config":
        print(json.dumps(load_config(), indent=2))
    elif args.command == "gen":
        cmd_gen(force_type=args.type or "")
    else:
        p.print_help()


if __name__ == "__main__":
    main()
